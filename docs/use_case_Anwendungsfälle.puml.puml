@startuml
title CRM-System Anwendungsfälle (Use-Case-Diagramm)

left to right direction
skinparam packageStyle rectangle

actor "Sales-Mitarbeiter" as Sales
actor "Administrator" as Admin

rectangle "CRM System (Flask + SQLite)" {
  usecase "Kunden-Stammdaten pflegen" as UC1
  usecase "Leads verfolgen" as UC2
  usecase "Dashboard Statistiken" as UC3
  usecase "Daten in SQLite persistieren" as UC4
}

Sales --> UC1
Sales --> UC2
Sales --> UC3

' 数据库操作包含在核心业务逻辑中
UC1 ..> UC4 : <<include>>
UC2 ..> UC4 : <<include>>

Admin --|> Sales
@enduml