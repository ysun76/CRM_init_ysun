@startuml
entity "Customer" as cust {
  * id : INTEGER <<PK>>
  --
  name : TEXT
  email : TEXT
  company : TEXT
  created_at : DATETIME
}

entity "ContactPerson" as contact {
  * id : INTEGER <<PK>>
  --
  customer_id : INTEGER <<FK>>
